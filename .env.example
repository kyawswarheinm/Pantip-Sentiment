# Turso (cloud SQLite)
TURSO_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your_token_here

# Kaggle API
KAGGLE_USERNAME=your_username
KAGGLE_KEY=your_api_key
KAGGLE_DATASET_SLUG=your_username/pantip-set-sentiment

# Scraper behaviour
PANTIP_BASE_URL=https://pantip.com
SCRAPE_DELAY_MIN=2
SCRAPE_DELAY_MAX=5
MAX_POSTS_PER_RUN=100

# NLP
MODEL_NAME=cardiffnlp/twitter-xlm-roberta-base-sentiment
SENTIMENT_CONFIDENCE_THRESHOLD=0.65

# Alert thresholds
ZSCORE_THRESHOLD=2.5
VOLUME_SURGE_MULTIPLIER=3.0
LOOKBACK_DAYS_ALERT=7

# Dashboard
STREAMLIT_CACHE_TTL=900
